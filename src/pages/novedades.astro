---
import Base from "../layouts/Base.astro";
import { getExplorerIndex } from "../lib/data";
import guias from "../../data/guias.json";
import {
  CCAA_MAP,
  CCAA_SLUG,
  CATEGORIA_LABELS,
  CATEGORIA_COLORS,
  cleanName,
  fichaUrl,
} from "../lib/types";

const novedades = getExplorerIndex()
  .filter((d) => d.novedad_2025)
  .sort((a, b) => b.relevancia - a.relevancia);

// Agrupar por categoría, ordenadas por volumen desc
const byCategoria: Record<string, typeof novedades> = {};
for (const d of novedades) {
  if (!byCategoria[d.categoria]) byCategoria[d.categoria] = [];
  byCategoria[d.categoria].push(d);
}
const categoriasOrdenadas = Object.entries(byCategoria).sort(
  ([, a], [, b]) => b.length - a.length
);

const estatales = novedades.filter((d) => d.tipo === "estatal").length;
const autonomicas = novedades.filter((d) => d.tipo === "autonomica").length;
---

<Base
  title="Novedades IRPF 2025: nuevas deducciones fiscales"
  description={`${novedades.length} deducciones nuevas o modificadas en el IRPF 2025. Descubre qué ha cambiado este año: ${estatales} estatales y ${autonomicas} autonómicas con novedades para la declaración de la renta.`}
  ogImage="/og/novedades.png"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.larenta.es" },
      { "@type": "ListItem", "position": 2, "name": "Novedades IRPF 2025", "item": "https://www.larenta.es/novedades" },
    ]
  })} />

  <div style="background: var(--color-surface); min-height: 100vh;">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-10 sm:py-14">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-sm mb-8" style="color: var(--color-on-surface-variant);">
        <a href="/" class="hover:underline" style="color: var(--color-on-surface-variant);">Inicio</a>
        <span style="opacity: 0.4;">›</span>
        <span style="color: var(--color-on-surface);">Novedades IRPF 2025</span>
      </nav>

      <!-- Header -->
      <div class="mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color: var(--color-primary);">
          Campaña IRPF 2025
        </p>
        <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4"
          style="color: var(--color-on-surface); letter-spacing: -0.02ch;">
          Novedades IRPF 2025
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--color-on-surface-variant); max-width: 60ch;">
          <strong style="color: var(--color-on-surface);">{novedades.length} deducciones</strong> nuevas o
          modificadas para la declaración de la renta 2025. Comprueba si alguna de las novedades
          de este año aplica a tu situación.
        </p>
      </div>

      <!-- Stats rápidas -->
      <div class="grid grid-cols-3 gap-3 mb-10">
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{novedades.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Total novedades</div>
        </div>
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{estatales}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Estatales</div>
        </div>
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{autonomicas}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Autonómicas</div>
        </div>
      </div>

      <!-- Listado por categoría -->
      {categoriasOrdenadas.map(([cat, items]) => (
        <section class="mb-10" id={`cat-${cat}`}>
          <h2 class="flex items-center gap-2 text-base font-bold mb-4" style="color: var(--color-on-surface);">
            <a href={`/categoria/${cat}`} class="hover:underline" style="color: var(--color-on-surface);">
              <span class={`badge ${CATEGORIA_COLORS[cat] || "badge-otros"}`}>
                {CATEGORIA_LABELS[cat] || cat}
              </span>
            </a>
            <span class="text-sm font-normal" style="color: var(--color-on-surface-variant);">
              — {items.length} novedad{items.length !== 1 ? "es" : ""}
            </span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {items.map((d) => (
              <a
                href={fichaUrl(d.id)}
                class="card group transition-all hover:-translate-y-0.5"
                style="padding: 1.25rem 1.5rem; box-shadow: none; text-decoration: none;"
              >
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-1.5 mb-1.5">
                      {d.tipo === "autonomica" ? (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full"
                          style="background: var(--color-surface-high); color: var(--color-on-surface-variant);">
                          {d.comunidad}
                        </span>
                      ) : (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full"
                          style="background: var(--color-surface-high); color: var(--color-primary);">
                          Estatal
                        </span>
                      )}
                    </div>
                    <div class="text-sm font-semibold leading-snug mb-1" style="color: var(--color-on-surface);">
                      {cleanName(d.nombre_corto)}
                    </div>
                    {d.resumen && (
                      <div
                        class="text-xs leading-relaxed"
                        style="color: var(--color-on-surface-variant); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
                      >
                        {cleanName(d.resumen)}
                      </div>
                    )}
                    <div class="flex items-center gap-2 mt-1.5">
                      {d.porcentaje && (
                        <span class="text-xs font-bold" style="color: var(--color-primary);">
                          {cleanName(d.porcentaje)}
                        </span>
                      )}
                      <span class={`text-xs font-semibold ${d.relevancia === 3 ? "relevancia-alta" : d.relevancia === 2 ? "relevancia-media" : "relevancia-baja"}`}>
                        {d.relevancia === 3 ? "•••" : d.relevancia === 2 ? "••" : "•"}
                      </span>
                    </div>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-outline);">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- Guías relacionadas -->
      <section class="mb-10" aria-label="Guías relacionadas">
        <h2 class="text-base font-bold mb-4" style="color: var(--color-on-surface);">
          Guías para entender los cambios
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {guias.slice(0, 4).map((g) => (
            <a
              href={`/guia/${g.slug}`}
              class="card group flex items-center gap-3 transition-all hover:-translate-y-0.5"
              style="padding: 1rem 1.25rem; text-decoration: none;"
            >
              <span class="text-xl flex-shrink-0">{g.icono}</span>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold leading-snug" style="color: var(--color-on-surface);">
                  {g.titulo}
                </p>
                <p class="text-xs mt-0.5 line-clamp-1" style="color: var(--color-on-surface-variant);">
                  {g.subtitulo}
                </p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-outline);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>

      <!-- Footer links -->
      <div class="mt-8 pt-8 flex flex-col sm:flex-row gap-4 items-start"
        style="border-top: 1px solid var(--color-outline-variant);">
        <a href="/asistente" class="btn-primary">
          Descubrir mis deducciones →
        </a>
        <a href="/explorador" class="btn-text">
          Ver todas las deducciones
        </a>
      </div>

    </div>
  </div>
</Base>
