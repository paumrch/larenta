---
import Base from "../../layouts/Base.astro";
import { getDeduccionesByCategoria } from "../../lib/data";
import {
  CCAA_MAP,
  CCAA_SLUG,
  CATEGORIA_LABELS,
  CATEGORIA_COLORS,
  cleanName,
  fichaUrl,
} from "../../lib/types";

export function getStaticPaths() {
  const categorias = [
    "familia",
    "vivienda",
    "educacion",
    "salud",
    "empresa",
    "donativos",
    "energia",
    "movilidad",
    "otros",
  ];
  return categorias.map((cat) => ({
    params: { categoria: cat },
    props: { categoria: cat },
  }));
}

const { categoria } = Astro.props;

const label = CATEGORIA_LABELS[categoria] || categoria;
const labelTexto = label.replace(/^[^\s]+\s/, ""); // quita el emoji
const colorClass = CATEGORIA_COLORS[categoria] || "badge-otros";

const deducciones = getDeduccionesByCategoria(categoria);

// Separar estatales de autonómicas
const estatales = deducciones.filter((d) => d.tipo === "estatal");
const autonomicas = deducciones.filter((d) => d.tipo === "autonomica");

// Agrupar autonómicas por CCAA, ordenadas por número de deducciones desc
const byCCAA: Record<string, typeof autonomicas> = {};
for (const d of autonomicas) {
  if (!byCCAA[d.codigo_ccaa]) byCCAA[d.codigo_ccaa] = [];
  byCCAA[d.codigo_ccaa].push(d);
}
const ccaaOrdenadas = Object.entries(byCCAA).sort(
  ([, a], [, b]) => b.length - a.length
);

const canonicalUrl = `https://www.larenta.es/categoria/${categoria}`;

const totalCCAA = ccaaOrdenadas.length;
const novedades = deducciones.filter((d) => d.novedad_2025).length;
---

<Base
  title={`Deducciones IRPF ${labelTexto} 2025`}
  description={`${deducciones.length} deducciones de ${labelTexto.toLowerCase()} en el IRPF 2025: ${estatales.length} estatales y ${autonomicas.length} autonómicas en ${totalCCAA} comunidades. Requisitos e importes actualizados.`}
  ogImage={`/api/og?title=${encodeURIComponent("Deducciones " + labelTexto + " IRPF 2025")}&subtitle=${encodeURIComponent(deducciones.length + " deducciones · " + totalCCAA + " comunidades")}`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.larenta.es" },
      { "@type": "ListItem", "position": 2, "name": "Categorías", "item": "https://www.larenta.es/categoria" },
      { "@type": "ListItem", "position": 3, "name": labelTexto, "item": canonicalUrl },
    ]
  })} />

  <div style="background: var(--color-surface); min-height: 100vh;">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-10 sm:py-14">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-sm mb-8 flex-wrap" style="color: var(--color-on-surface-variant);">
        <a href="/" class="flex-shrink-0 hover:underline" style="color: var(--color-on-surface-variant);">Inicio</a>
        <span class="flex-shrink-0" style="opacity: 0.4;">›</span>
        <a href="/categoria" class="flex-shrink-0 hover:underline" style="color: var(--color-on-surface-variant);">Categorías</a>
        <span class="flex-shrink-0" style="opacity: 0.4;">›</span>
        <span class="font-medium" style="color: var(--color-on-surface);">{labelTexto}</span>
      </nav>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class={`badge ${colorClass}`}>{label}</span>
          <span class="badge" style="background: var(--color-surface-high); color: var(--color-on-surface-variant);">
            IRPF 2025
          </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4"
          style="color: var(--color-on-surface); letter-spacing: -0.02ch;">
          Deducciones de {labelTexto.toLowerCase()}<br class="hidden sm:block" /> en el IRPF 2025
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--color-on-surface-variant); max-width: 60ch;">
          {deducciones.length} deducciones disponibles en esta categoría: {estatales.length} {estatales.length === 1 ? "estatal" : "estatales"}
          {autonomicas.length > 0 && ` y ${autonomicas.length} autonómicas en ${totalCCAA} ${totalCCAA === 1 ? "comunidad" : "comunidades"}`}.
        </p>
      </div>

      <!-- Stats rápidas -->
      <div class="grid grid-cols-3 gap-3 mb-10">
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{deducciones.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Total</div>
        </div>
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{estatales.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Estatales</div>
        </div>
        <div class="card-inset text-center">
          <div class="text-2xl font-extrabold" style="color: var(--color-primary);">{novedades}</div>
          <div class="text-xs mt-1" style="color: var(--color-on-surface-variant);">Novedades 2025</div>
        </div>
      </div>

      <!-- Deducciones estatales -->
      {estatales.length > 0 && (
        <section class="mb-10">
          <h2 class="flex items-center gap-2 text-base font-bold mb-4" style="color: var(--color-on-surface);">
            <span class="badge" style="background: var(--color-surface-high); color: var(--color-primary);">Estatal</span>
            <span class="text-sm font-normal" style="color: var(--color-on-surface-variant);">— {estatales.length} deducción{estatales.length !== 1 ? "es" : ""} para todos</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {estatales.map((d) => (
              <a
                href={fichaUrl(d.id)}
                class="card group transition-all hover:-translate-y-0.5"
                style="padding: 1.25rem 1.5rem; box-shadow: none; text-decoration: none;"
              >
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0 flex-1">
                    <div class="text-sm font-semibold leading-snug mb-1" style="color: var(--color-on-surface);">
                      {cleanName(d.nombre_corto)}
                    </div>
                    {d.resumen && (
                      <div
                        class="text-xs leading-relaxed"
                        style="color: var(--color-on-surface-variant); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
                      >
                        {cleanName(d.resumen)}
                      </div>
                    )}
                    <div class="flex items-center gap-2 mt-2">
                      {d.porcentaje && (
                        <span class="text-xs font-bold" style="color: var(--color-primary);">
                          {cleanName(d.porcentaje)}
                        </span>
                      )}
                      {d.novedad_2025 && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full font-semibold"
                          style="background: var(--color-secondary-fixed); color: var(--color-on-secondary-container);">
                          ✨ Novedad
                        </span>
                      )}
                      <span class={`text-xs font-semibold ${d.relevancia === 3 ? "relevancia-alta" : d.relevancia === 2 ? "relevancia-media" : "relevancia-baja"}`}>
                        {d.relevancia === 3 ? "•••" : d.relevancia === 2 ? "••" : "•"}
                      </span>
                    </div>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-outline);">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Deducciones autonómicas agrupadas por CCAA -->
      {ccaaOrdenadas.map(([codigo, items]) => (
        <section class="mb-10" id={`ccaa-${codigo.toLowerCase()}`}>
          <h2 class="flex items-center gap-2 text-base font-bold mb-4" style="color: var(--color-on-surface);">
            <a
              href={CCAA_SLUG[codigo] ? `/comunidad/${CCAA_SLUG[codigo]}` : `/explorador?ccaa=${codigo}`}
              class="hover:underline"
              style="color: var(--color-on-surface);"
            >
              {CCAA_MAP[codigo]}
            </a>
            <span class="text-sm font-normal" style="color: var(--color-on-surface-variant);">
              — {items.length} deducción{items.length !== 1 ? "es" : ""}
            </span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {items.map((d) => (
              <a
                href={fichaUrl(d.id)}
                class="card group transition-all hover:-translate-y-0.5"
                style="padding: 1.25rem 1.5rem; box-shadow: none; text-decoration: none;"
              >
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0 flex-1">
                    <div class="text-sm font-semibold leading-snug mb-1" style="color: var(--color-on-surface);">
                      {cleanName(d.nombre_corto)}
                    </div>
                    {d.resumen && (
                      <div
                        class="text-xs leading-relaxed"
                        style="color: var(--color-on-surface-variant); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
                      >
                        {cleanName(d.resumen)}
                      </div>
                    )}
                    <div class="flex items-center gap-2 mt-2">
                      {d.porcentaje && (
                        <span class="text-xs font-bold" style="color: var(--color-primary);">
                          {cleanName(d.porcentaje)}
                        </span>
                      )}
                      {d.novedad_2025 && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full font-semibold"
                          style="background: var(--color-secondary-fixed); color: var(--color-on-secondary-container);">
                          ✨ Novedad
                        </span>
                      )}
                      <span class={`text-xs font-semibold ${d.relevancia === 3 ? "relevancia-alta" : d.relevancia === 2 ? "relevancia-media" : "relevancia-baja"}`}>
                        {d.relevancia === 3 ? "•••" : d.relevancia === 2 ? "••" : "•"}
                      </span>
                    </div>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-outline);">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- Footer links -->
      <div class="mt-8 pt-8 flex flex-col sm:flex-row gap-4 items-start"
        style="border-top: 1px solid var(--color-outline-variant);">
        <a href="/asistente" class="btn-primary">
          Descubrir mis deducciones →
        </a>
        <a href="/categoria" class="btn-text">
          ← Otras categorías
        </a>
      </div>

    </div>
  </div>
</Base>
