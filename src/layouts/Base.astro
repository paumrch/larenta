---
import { getStats } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const stats = getStats();

const {
  title,
  description = `Descubre todas las deducciones del IRPF 2025 en segundos. Asistente interactivo + explorador con las ${stats.total_deducciones} deducciones estatales y autonómicas.`,
  ogImage = "/og/home.png",
  canonical,
} = Astro.props;

const siteUrl = "https://www.larenta.es";
const pageUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = title === "larenta.es" ? title + " — Tu guía completa del IRPF 2025" : `${title} | larenta.es`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="larenta.es" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

    <!-- JSON-LD Structured Data -->
    <slot name="head" />

    <!-- Fonts: Public Sans (The Civic Ledger) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      @import "../styles/global.css";
    </style>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-P5HKM4NQ');</script>
    <!-- End Google Tag Manager -->

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-9BMRQTWEG5"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9BMRQTWEG5');
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background: var(--color-surface);">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P5HKM4NQ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Nav glassmorphic -->
    <header class="sticky top-0 z-50 glass" style="box-shadow: 0 1px 0 var(--color-outline-variant);">
      <nav class="max-w-6xl mx-auto px-4 sm:px-8 h-14 sm:h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="group flex-shrink-0" aria-label="larenta.es - Inicio">
          <img src="/LR.svg" alt="laRenta.es" class="h-6 sm:h-7 w-auto" />
        </a>

        <!-- Desktop nav links -->
        <div class="hidden sm:flex items-center gap-1">
          <a
            href="/guia"
            class:list={["px-4 py-2 text-sm font-medium rounded-xl transition-colors", 
              currentPath.startsWith('/guia') ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            Guía IRPF
          </a>
          <a
            href="/asistente"
            class:list={["px-4 py-2 text-sm font-medium rounded-xl transition-colors",
              currentPath === '/asistente' ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            Asistente
          </a>
          <a
            href="/explorador"
            class:list={["px-4 py-2 text-sm font-medium rounded-xl transition-colors",
              currentPath === '/explorador' ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            Deducciones
          </a>
          <a
            href="/asistente"
            class="btn-primary ml-2 !py-2 !px-4 !text-sm"
          >
            Calcular mi renta
          </a>
        </div>

        <!-- Mobile hamburger button -->
        <button
          id="mobile-menu-btn"
          class="sm:hidden flex items-center justify-center w-10 h-10 rounded-xl transition-colors"
          style="background: transparent; border: none; cursor: pointer; color: var(--color-on-surface);"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu panel -->
      <div
        id="mobile-menu"
        class="sm:hidden hidden"
        style="background: var(--color-surface-lowest); border-top: 1px solid var(--color-outline-variant); box-shadow: 0 8px 24px rgba(0,0,0,0.08);"
      >
        <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1">
          <a
            href="/guia"
            class:list={["flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-colors",
              currentPath.startsWith('/guia') ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Guía IRPF 2025
          </a>
          <a
            href="/asistente"
            class:list={["flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-colors",
              currentPath === '/asistente' ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            Asistente interactivo
          </a>
          <a
            href="/explorador"
            class:list={["flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-colors",
              currentPath === '/explorador' ? "text-[var(--color-primary)] bg-[var(--color-surface-high)]" : "text-[var(--color-on-surface)] hover:bg-[var(--color-surface-high)]"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
            Explorador de deducciones
          </a>
          <div class="pt-2 pb-1">
            <a
              href="/asistente"
              class="btn-primary w-full justify-center !text-sm"
            >
              Calcular mis deducciones →
            </a>
          </div>
        </div>
      </div>
    </header>

    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var iconOpen = document.getElementById('menu-icon-open');
        var iconClose = document.getElementById('menu-icon-close');
        if (!btn || !menu || !iconOpen || !iconClose) return;

        btn.addEventListener('click', function() {
          var open = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          iconOpen.classList.toggle('hidden');
          iconClose.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        });
      })();
    </script>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background: #e8edf3; color: var(--color-on-surface);">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-14">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-10">
          <!-- Marca -->
          <div class="sm:col-span-2">
            <a href="/" aria-label="larenta.es - Inicio">
              <img src="/LR.svg" alt="laRenta.es" class="h-7 w-auto" />
            </a>
            <p class="mt-3 text-sm max-w-xs leading-relaxed" style="color: var(--color-on-surface-variant);">
              Tu guía completa del IRPF 2025. Deducciones estatales y autonómicas explicadas de forma clara, con datos oficiales de la AEAT.
            </p>
          </div>

          <!-- Herramientas -->
          <div>
            <h4 class="text-sm font-semibold mb-4" style="color: var(--color-on-surface);">Herramientas</h4>
            <ul class="space-y-2.5 text-sm" style="color: var(--color-on-surface-variant);">
              <li><a href="/asistente" class="hover:text-[var(--color-primary)] transition-colors">Asistente interactivo</a></li>
              <li><a href="/explorador" class="hover:text-[var(--color-primary)] transition-colors">Explorador de deducciones</a></li>
              <li><a href="/guia" class="hover:text-[var(--color-primary)] transition-colors">Guía IRPF 2025</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="text-sm font-semibold mb-4" style="color: var(--color-on-surface);">Fuentes y legal</h4>
            <ul class="space-y-2.5 text-sm" style="color: var(--color-on-surface-variant);">
              <li>
                <a href="https://sede.agenciatributaria.gob.es" target="_blank" rel="noopener noreferrer"
                  class="hover:text-[var(--color-primary)] transition-colors">
                  AEAT — Agencia Tributaria ↗
                </a>
              </li>
              <li>
                <a href="/elproyecto" class="hover:text-[var(--color-primary)] transition-colors">
                  Sobre este proyecto
                </a>
              </li>
              <li class="text-xs pt-1 leading-relaxed" style="color: var(--color-on-surface-variant); opacity: 0.7;">
                Información orientativa. No constituye asesoramiento fiscal. Consulta siempre con un profesional.
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs"
          style="border-top: 1px solid rgba(0,0,0,0.1); color: var(--color-on-surface-variant);">
          <span>© {new Date().getFullYear()} larenta.es</span>
          <a href="https://github.com/paumrch/larenta" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 hover:text-[var(--color-primary)] transition-colors text-xs">
            <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Open source en GitHub
          </a>
          <span>Datos del Manual de la Renta 2025 — AEAT</span>
        </div>
      </div>
    </footer>
  </body>
</html>
